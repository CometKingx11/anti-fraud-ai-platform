# .env 配置文件示例
# 复制此文件为 .env 并填入真实的 API Key

# Flask 应用密钥（用于加密 Session、CSRF Token 等）
# 生产环境请使用强随机字符串（至少 32 字节）
SECRET_KEY=your-secret-key-here-at-least-32-bytes-long

# 数据库配置
DATABASE_URL=sqlite:///anti_fraud_dev.db
DEV_DATABASE_URL=sqlite:///anti_fraud_dev.db

# DashScope（通义千问）API Key
# 获取地址：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# 360 开放平台 API Key（用于 URL 安全检测）
# 获取地址：https://openapi.360.cn/
# 免费额度：每日 1000 次
360_API_KEY=your-360-api-key-here

# 腾讯电脑管家 API Key（用于 URL 安全检测）
# 获取地址：https://open.qq.com/
# 免费额度：每日 5000 次
TENCENT_API_KEY=your-tencent-api-key-here

# 上传文件存储目录
UPLOAD_FOLDER=uploads

# 日志级别（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=INFO

# Flask 运行环境（development, production, testing）
FLASK_ENV=development
